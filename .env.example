# PicoDual repo: pico-aws agent (S3) + pico-flare agent (Cloudflare)
# Copy to .env and fill in values for the entrypoint you use.

# ── LLM (OpenRouter recommended; required for picoflare) ─
# OPENROUTER_API_KEY=sk-or-v1-xxx
# OPENROUTER_MODEL=moonshotai/kimi-k2.5
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx

# ── Chat channels (picoclaw gateway) ─
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx

# ── AWS (picoclaw: S3 memory + MCP tools) ─
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# PICOCLAW_MEMORY_S3_BUCKET=my-pico-combined-memory
# PICOCLAW_MEMORY_S3_PREFIX=
# PICOCLAW_MEMORY_S3_REGION=

# ── Cloudflare (picoflare: R2, Vectorize, MCP) ─
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# ── Telegram webhook (picoflare bot behind proxy) ─
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/bot
# TELEGRAM_WEBHOOK_PATH=/bot
# TELEGRAM_WEBHOOK_LISTEN=:8080

# ── Timezone ─
TZ=Asia/Tokyo
